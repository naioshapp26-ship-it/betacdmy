# Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://db_user:db_password@db_host:5432/db_name

# ============================================
# Persistent File Storage
# ============================================
# Set this to the Railway Volume mount path to persist uploads across deployments.
# In Railway: add a Volume to your service and mount it at /uploads, then set:
# UPLOAD_DIR=/uploads
UPLOAD_DIR=

# Optional: when tenant-facing tables live in a different DB than CENTRAL_DATABASE_URL.
TENANT_DATABASE_URL=

# ============================================
# AI Provider Keys
# ============================================
# Gemini/OpenAI/Claude API keys are NOT managed via environment variables.
# Use the Super Admin or Tenant Admin dashboards (Settings → AI Integration)
# to store provider credentials directly in the database with encryption.
# Leaving keys out of .env keeps local builds consistent with production.

# ============================================
# SMTP Email Configuration (Optional)
# ============================================
# If not configured, emails will not be sent but app will continue to work

# SMTP Server
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Authentication
SMTP_USER=your-username
SMTP_PASS=your-password

# From Address
SMTP_FROM=noreply@yourdomain.com

# ============================================
# Examples for Popular Providers
# ============================================

# Gmail (requires App Password: https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@gmail.com

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com

# Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASS=your-mailgun-password
# SMTP_FROM=noreply@yourdomain.com

# AWS SES (requires verified sender)
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-aws-ses-smtp-username
# SMTP_PASS=your-aws-ses-smtp-password
# SMTP_FROM=verified@yourdomain.com

# ============================================
# Stripe Payment Configuration (Optional)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Security
# ============================================
TENANT_DB_ENCRYPTION_KEY=your-encryption-key-change-this
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins for API requests
# Examples:
#   Development: http://localhost:3000,http://localhost:5173
#   Production: https://yourdomain.com,https://www.yourdomain.com
#   Wildcard subdomain: https://*.yourdomain.com
#   All origins (NOT RECOMMENDED for production): *
#
# If not set, defaults to:
#   - Development: localhost origins (3000, 5173, 127.0.0.1)
#   - Production: MAIN_DOMAIN if set, otherwise restricted
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Allow all origins for media files (videos, images)
# Set to 'true' to allow public media streaming from any origin
# Default: false (uses CORS_ALLOWED_ORIGINS)
CORS_MEDIA_ALLOW_ALL=false

# Main domain for automatic CORS configuration
# MAIN_DOMAIN=yourdomain.com
# PROTOCOL=https

# Railway deployment domain (for CORS)
# RAILWAY_PUBLIC_DOMAIN=your-app-production.up.railway.app

# ============================================
# Testing (Optional)
# ============================================
# Email address to use for testing email functionality
TEST_EMAIL=your-test@email.com
