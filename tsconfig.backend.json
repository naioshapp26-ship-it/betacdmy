{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "backend/src",
    "outDir": "backend/dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "declaration": false,
    "sourceMap": false,
    "noEmit": false
  },
  "include": ["backend/src/**/*.ts"]
}
